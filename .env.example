# ─── Supabase ────────────────────────────────────────────────────────────────
# Copy these from your Supabase project → Settings → API

# Public anon key — safe to expose in the browser (used by Next.js server components)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service-role key — server/script only, NEVER expose to the browser
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Used by scripts/sync-tools.ts (GitHub Actions) to discover new tools via Claude
ANTHROPIC_API_KEY=sk-ant-...

# ─── Vercel ──────────────────────────────────────────────────────────────────
# Deploy hook URL — triggers a redeploy after the sync script adds new tools.
# Create at: Vercel Dashboard → Your Project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/...
